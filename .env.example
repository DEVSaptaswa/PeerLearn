# Copy to .env and fill in real values.
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

MYSQL_DB=peer_learning
MYSQL_USER=peerlearn
MYSQL_PASSWORD=changeme
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_HOST=mysql
MYSQL_PORT=3306

MONGO_URI=mongodb://peerlearn:changeme@mongo:27017/peer_learning?authSource=peer_learning
MONGO_DB=peer_learning
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme_mongo_root
MONGO_APP_PASSWORD=changeme_mongo_app

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=changeme_redis

SEED_DATA=true
